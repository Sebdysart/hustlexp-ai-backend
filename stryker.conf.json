{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "testRunner": "vitest",
  "testRunnerNodeArgs": ["--max-old-space-size=2048"],
  "mutate": [
    "backend/src/services/TaskReservationService.ts:53-59",
    "backend/src/services/DispatchExpiryService.ts:160-184",
    "backend/src/services/PendingPaymentCancellationService.ts:136-162",
    "backend/src/services/StripePaymentIntentCancellationService.ts:15-20",
    "backend/src/jobs/dispatch-expiry-payment-cancel-worker.ts:22-36"
  ],
  "mutator": {
    "excludedMutations": ["ArrayDeclaration", "BlockStatement", "ObjectLiteral", "StringLiteral"]
  },
  "ignoreStatic": true,
  "vitest": {
    "configFile": "vitest.mutation.config.ts",
    "related": false
  },
  "concurrency": 4,
  "timeoutMS": 120000,
  "timeoutFactor": 1.5,
  "thresholds": {
    "high": 100,
    "low": 100,
    "break": 100
  },
  "reporters": ["clear-text", "progress"]
}
