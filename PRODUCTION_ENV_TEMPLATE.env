# =============================================================================
# HustleXP Backend — Production Environment Template
# =============================================================================
# Copy this file to .env.production (or set vars in your hosting platform).
# DO NOT commit .env.production to git — it contains live secrets.
#
# All variables marked [REQUIRED] will cause a hard startup failure if missing.
# Variables marked [REQUIRED IN PROD] only block startup when NODE_ENV=production.
# Variables marked [OPTIONAL] degrade features but do not block startup.
#
# Last updated: 2026-03-07
# =============================================================================


# =============================================================================
# Application
# =============================================================================

# [REQUIRED] Must be "production" to activate all validation paths, HSTS, and
# strict CORS enforcement. Any other value is treated as development.
NODE_ENV=production

# [OPTIONAL] HTTP port the server binds to. Default: 3000.
# Your reverse proxy (nginx, Caddy) should forward HTTPS traffic to this port.
PORT=3000

# [REQUIRED IN PROD] Comma-separated list of allowed CORS origins.
# Must be HTTPS URLs. Wildcards (*) are rejected in production.
# Example: https://app.hustlexp.com,https://admin.hustlexp.com
# The server calls process.exit(1) at startup if this is empty or contains "*".
ALLOWED_ORIGINS=https://app.hustlexp.com


# =============================================================================
# Database (Neon PostgreSQL)
# =============================================================================

# [REQUIRED] Full Neon PostgreSQL connection string including sslmode=require.
# Format: postgresql://{user}:{password}@{host}/{dbname}?sslmode=require
# Get from: Neon Dashboard → Project → Connection string
DATABASE_URL=postgresql://neondb_owner:REPLACE_ME@ep-REPLACE_ME.us-east-1.aws.neon.tech/neondb?sslmode=require

# [OPTIONAL] Enable PgBouncer transaction-mode pooling (Neon serverless driver).
# Set to "true" if connecting through a PgBouncer proxy.
DB_PGBOUNCER=false

# [OPTIONAL] Maximum number of pooled DB connections. Default: 20.
# Neon free tier: keep <= 10. Paid tier: adjust to your compute size.
DB_POOL_MAX=20

# [OPTIONAL] Milliseconds before an idle connection is closed. Default: 30000.
DB_IDLE_TIMEOUT_MS=30000

# [OPTIONAL] Milliseconds before a connection attempt times out. Default: 10000.
DB_CONNECT_TIMEOUT_MS=10000

# [OPTIONAL] Per-statement query timeout in milliseconds. Default: 30000.
# Queries exceeding this are cancelled — prevents runaway queries from blocking the pool.
DB_STATEMENT_TIMEOUT_MS=30000


# =============================================================================
# Redis / Upstash
# =============================================================================

# [REQUIRED IN PROD] Upstash Redis REST API URL for @upstash/redis client.
# Used by: rate limiting, feed cache, Stripe Connect cache.
# Get from: Upstash Console → Database → REST API
UPSTASH_REDIS_REST_URL=https://REPLACE_ME.upstash.io

# [REQUIRED IN PROD] Upstash Redis REST token (pairs with UPSTASH_REDIS_REST_URL).
UPSTASH_REDIS_REST_TOKEN=REPLACE_ME

# [REQUIRED IN PROD] Direct TCP Redis connection string for BullMQ (ioredis).
# Format: redis://default:{password}@{endpoint}:6379
# For Upstash: use the "Direct Connection" URL from the Upstash console.
# For self-hosted Redis: redis://localhost:6379
# This MUST be a non-evicting Redis instance — BullMQ cannot afford to lose jobs.
UPSTASH_REDIS_URL=redis://default:REPLACE_ME@REPLACE_ME.upstash.io:6379


# =============================================================================
# Stripe (Payments)
# =============================================================================

# [REQUIRED] Live-mode Stripe secret key. Must start with "sk_live_".
# DO NOT use "sk_test_" in production — payments will silently fail.
# Get from: Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_live_REPLACE_ME

# [REQUIRED] Stripe webhook endpoint signing secret.
# Generated when you register the webhook endpoint in the Stripe Dashboard.
# Endpoint URL: https://api.hustlexp.com/webhooks/stripe
# Required events: payment_intent.succeeded, transfer.created,
#   checkout.session.completed, customer.subscription.{created,updated,deleted},
#   invoice.payment_failed, account.updated, capability.updated,
#   payout.failed, charge.dispute.created
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# [OPTIONAL] Platform fee percentage taken from each completed task. Default: 15.
# Per PRODUCT_SPEC §9: 15% platform fee.
PLATFORM_FEE_PERCENT=15

# [OPTIONAL] Minimum task value in cents. Default: 500 ($5.00).
MIN_TASK_VALUE_CENTS=500

# [OPTIONAL] Stripe Price IDs for subscription tiers (live-mode Price IDs).
# Obtain after creating Products and Prices in the Stripe live Dashboard.
STRIPE_PREMIUM_MONTHLY_PRICE_ID=price_REPLACE_ME
STRIPE_PREMIUM_YEARLY_PRICE_ID=price_REPLACE_ME
STRIPE_PRO_MONTHLY_PRICE_ID=price_REPLACE_ME
STRIPE_PRO_YEARLY_PRICE_ID=price_REPLACE_ME
STRIPE_FREE_PRICE_ID=price_REPLACE_ME
STRIPE_PREMIUM_PRICE_ID=price_REPLACE_ME
STRIPE_PRO_PRICE_ID=price_REPLACE_ME


# =============================================================================
# Firebase (Authentication + Push Notifications)
# =============================================================================

# [REQUIRED IN PROD] Firebase project ID for the production project.
# Get from: Firebase Console → Project Settings → General → Project ID
FIREBASE_PROJECT_ID=hustlexp-prod

# [REQUIRED IN PROD] Firebase service account private key (RSA private key).
# Get from: Firebase Console → Project Settings → Service accounts → Generate new private key
# Paste the "private_key" value from the downloaded JSON. Keep \n escapes intact.
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nREPLACE_ME\n-----END PRIVATE KEY-----\n

# [REQUIRED IN PROD] Firebase service account client email.
# Format: firebase-adminsdk-{id}@{project}.iam.gserviceaccount.com
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-REPLACE_ME@hustlexp-prod.iam.gserviceaccount.com

# [OPTIONAL] Firebase Web API key (used for client-side auth in admin tools).
# Get from: Firebase Console → Project Settings → General → Web API key
FIREBASE_WEB_API_KEY=REPLACE_ME


# =============================================================================
# Cloudflare R2 (Object Storage)
# =============================================================================

# [REQUIRED IN PROD] Cloudflare account ID.
# Get from: Cloudflare Dashboard → right sidebar → Account ID
R2_ACCOUNT_ID=REPLACE_ME

# [REQUIRED IN PROD] R2 API token access key ID.
# Create a dedicated token: Cloudflare Dashboard → R2 → Manage API Tokens
# Scope it to the production bucket only with object read/write permissions.
R2_ACCESS_KEY_ID=REPLACE_ME

# [REQUIRED IN PROD] R2 API token secret access key (pairs with R2_ACCESS_KEY_ID).
R2_SECRET_ACCESS_KEY=REPLACE_ME

# [REQUIRED IN PROD] Name of the production R2 bucket.
# Do NOT reuse the development bucket. Create a separate production bucket.
R2_BUCKET_NAME=hustlexp-storage-prod


# =============================================================================
# AI Services (Multi-model routing)
# =============================================================================

# [OPTIONAL] OpenAI API key. Used for GPT-4o safety layer and primary AI calls.
# Missing → AI safety layer disabled (warning logged, startup not blocked).
OPENAI_API_KEY=sk-REPLACE_ME

# [OPTIONAL] OpenAI model override. Default: gpt-4o.
OPENAI_MODEL=gpt-4o

# [OPTIONAL] Groq API key. Used for fast inference (llama-3.3-70b-versatile).
# Missing → fast inference path disabled; falls back to OpenAI.
GROQ_API_KEY=gsk_REPLACE_ME

# [OPTIONAL] Groq model override. Default: llama-3.3-70b-versatile.
GROQ_MODEL=llama-3.3-70b-versatile

# [OPTIONAL] DeepSeek API key. Used for reasoning tasks (deepseek-r1).
# Missing → deep reasoning path disabled.
DEEPSEEK_API_KEY=REPLACE_ME

# [OPTIONAL] DeepSeek model override. Default: deepseek-r1.
DEEPSEEK_MODEL=deepseek-r1

# [OPTIONAL] Anthropic API key. Used as safety model fallback (claude-sonnet).
# Missing → Anthropic safety fallback disabled.
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# [OPTIONAL] Anthropic model override.
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# [OPTIONAL] Alibaba API key. Used as backup AI model (qwen-max).
ALIBABA_API_KEY=REPLACE_ME

# [OPTIONAL] AI response cache TTL in seconds. Default: 86400 (24 hours).
AI_CACHE_TTL=86400

# [OPTIONAL] Set to "true" to force degraded AI mode: all AI requests are queued
# instead of executed inline. Useful as an emergency circuit breaker.
AI_DEGRADED_MODE=false

# [OPTIONAL] Max milliseconds a queued AI request is considered pending. Default: 5000.
AI_MAX_QUEUE_WAIT_MS=5000


# =============================================================================
# Identity & Notifications
# =============================================================================

# [OPTIONAL] Twilio Account SID for phone verification (OTP).
TWILIO_ACCOUNT_SID=ACREPLACE_ME

# [OPTIONAL] Twilio Auth Token (pairs with TWILIO_ACCOUNT_SID).
TWILIO_AUTH_TOKEN=REPLACE_ME

# [OPTIONAL] Twilio Verify Service SID for OTP delivery.
TWILIO_VERIFY_SERVICE_SID=VAREPLACE_ME

# [OPTIONAL] SendGrid API key for transactional email (verification, receipts).
# Missing → email notifications silently fail.
SENDGRID_API_KEY=SG.REPLACE_ME

# [OPTIONAL] From-address for SendGrid emails.
SENDGRID_FROM_EMAIL=verify@hustlexp.app

# [OPTIONAL] Google Maps API key for geocoding and geofence queries.
GOOGLE_MAPS_API_KEY=REPLACE_ME


# =============================================================================
# Tax & Financial Compliance
# =============================================================================

# [REQUIRED IN PROD] AES-256-GCM encryption key for Tax Identification Numbers (TIN).
# Must be exactly 64 hex characters (32 bytes).
# Generate with: openssl rand -hex 32
# Store this securely — losing it makes stored TINs unrecoverable.
TAX_TIN_ENCRYPTION_KEY=REPLACE_WITH_64_HEX_CHARS


# =============================================================================
# Monitoring & Observability
# =============================================================================

# [OPTIONAL] Sentry DSN for error tracking and performance monitoring.
# Get from: Sentry Dashboard → Project → Settings → Client Keys (DSN)
# Use the production project DSN, not the development DSN.
SENTRY_DSN=https://REPLACE_ME@REPLACE_ME.ingest.sentry.io/REPLACE_ME

# [OPTIONAL] Sentry traces sample rate (0.0 to 1.0). Default: 0.1 (10%).
# Increase to 0.5 during initial launch for better observability; reduce under high load.
SENTRY_TRACES_SAMPLE_RATE=0.1

# [OPTIONAL] Enable Datadog APM integration. Default: false.
DATADOG_ENABLED=false

# [OPTIONAL] Datadog agent host. Default: localhost.
DD_AGENT_HOST=localhost

# [OPTIONAL] Datadog agent StatsD port. Default: 8125.
DD_AGENT_PORT=8125

# [OPTIONAL] Datadog service name reported in APM.
DD_SERVICE=hustlexp-api

# [OPTIONAL] Datadog environment tag. Defaults to NODE_ENV.
DD_ENV=production

# [OPTIONAL] Datadog version tag. Defaults to npm package version.
DD_VERSION=1.0.0

# [OPTIONAL] OpenTelemetry OTLP endpoint for trace export.
# Example: http://localhost:4318/v1/traces (local Jaeger or OTel Collector)
# Omit this variable to log traces to console only.
OTEL_EXPORTER_OTLP_ENDPOINT=

# [OPTIONAL] Service name reported in OTel spans. Default: hustlexp-ai-backend.
SERVICE_NAME=hustlexp-ai-backend


# =============================================================================
# Beta Configuration
# =============================================================================

# [OPTIONAL] Enable Seattle Metro private beta restrictions.
BETA_ENABLED=true

# [OPTIONAL] Beta start and end dates (ISO 8601).
BETA_START_DATE=2026-02-22
BETA_END_DATE=2026-03-24


# =============================================================================
# Background Check (Checkr) — Deferred to B3 (post-beta)
# =============================================================================

# [OPTIONAL] Checkr API key for background check integration.
# Currently deferred — Checkr account authorization pending.
# Account: hustlr on dashboard.checkr.com
CHECKR_API_KEY=REPLACE_ME


# =============================================================================
# Kill Switch / Safety
# =============================================================================

# [OPTIONAL] Set to "true" to disable all outbound payouts globally.
# Use in emergencies (e.g., suspected fraud wave). Default: false.
PAYOUTS_DISABLED=false
