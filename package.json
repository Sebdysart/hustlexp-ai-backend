{
  "name": "hustlexp-ai-backend",
  "version": "1.0.0",
  "main": "backend/src/server.ts",
  "type": "module",
  "scripts": {
    "dev": "tsx --watch backend/src/server.ts",
    "dev:old": "tsx backend/server.ts",
    "dev:workers": "tsx --watch backend/src/jobs/workers.ts",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "compile": "tsc",
    "start": "node dist/backend/src/server.js",
    "start:dev": "tsx backend/src/server.ts",
    "start:workers": "node dist/backend/src/jobs/workers.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:kill": "DATABASE_URL=$DATABASE_URL vitest run backend/tests/invariants/ --reporter=verbose",
    "test:invariants": "DATABASE_URL=$DATABASE_URL vitest run backend/tests/invariants/ --reporter=verbose",
    "test:all": "vitest run",
    "evil:a": "HX_STRIPE_STUB=1 node scripts/test-evil-a-split-transfer-fail.mjs",
    "evil:b": "node scripts/test-evil-b.js",
    "verify:realtime": "npx tsx scripts/verify-realtime-transport.ts",
    "db:check": "node migrate-pg.mjs",
    "db:migrate": "node migrate-pg.mjs",
    "db:validate": "npx tsx scripts/validate-schema.ts",
    "db:migrate:consolidate": "npx tsx scripts/consolidate-migrations.ts",
    "health": "curl http://localhost:3000/health",
    "lint": "eslint backend/src --ext .ts",
    "lint:fix": "eslint backend/src --ext .ts --fix",
    "format": "prettier --write \"backend/src/**/*.ts\"",
    "format:check": "prettier --check \"backend/src/**/*.ts\"",
    "generate:test-stubs": "tsx scripts/generate-test-stubs.ts",
    "check:tdad": "bash scripts/check-test-coverage-pr.sh",
    "index-docs": "tsx scripts/index-docs.ts",
    "query-docs": "tsx scripts/query-docs.ts",
    "generate:type-manifest": "tsx scripts/generate-type-manifest.ts",
    "incident-report": "tsx scripts/generate-incident-report.ts",
    "greptile:review": "tsx scripts/greptile-pr-review.ts",
    "test:vault": "vitest run 'tests-vault/**/*.test.ts'",
    "test:new": "vitest run 'backend/tests/new/**/*.test.ts'"
  },
  "dependencies": {
    "@aws-sdk/client-rekognition": "3.994.0",
    "@aws-sdk/client-s3": "3.966.0",
    "@aws-sdk/s3-request-presigner": "3.966.0",
    "@hono/node-server": "1.19.7",
    "@hono/trpc-server": "0.4.0",
    "@neondatabase/serverless": "1.0.2",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.70.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.212.0",
    "@opentelemetry/instrumentation-http": "^0.211.0",
    "@opentelemetry/instrumentation-pg": "^0.63.0",
    "@opentelemetry/sdk-node": "^0.212.0",
    "@opentelemetry/sdk-trace-base": "^2.5.1",
    "@sendgrid/mail": "8.1.6",
    "@sentry/node": "10.39.0",
    "@trpc/server": "11.7.1",
    "@upstash/ratelimit": "2.0.4",
    "@upstash/redis": "1.36.1",
    "bcrypt": "6.0.0",
    "bullmq": "5.66.4",
    "decimal.js": "10.6.0",
    "dotenv": "16.4.5",
    "fast-check": "^4.5.3",
    "firebase-admin": "13.6.0",
    "groq-sdk": "0.7.0",
    "hono": "4.10.5",
    "ioredis": "5.9.1",
    "jose": "6.1.3",
    "node-statsd": "0.1.1",
    "openai": "4.68.0",
    "pg": "8.16.3",
    "pino": "9.4.0",
    "pino-pretty": "11.2.2",
    "prom-client": "15.1.3",
    "stripe": "20.0.0",
    "superjson": "2.2.1",
    "ts-pattern": "^5.9.0",
    "tsx": "4.19.1",
    "twilio": "5.10.7",
    "typescript": "5.9.3",
    "ulidx": "2.4.1",
    "uuid": "10.0.0",
    "ws": "8.19.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@google/generative-ai": "^0.24.1",
    "@modelcontextprotocol/sdk": "1.25.2",
    "@noble/ed25519": "^3.0.0",
    "@noble/hashes": "^2.0.1",
    "@types/bcrypt": "6.0.0",
    "@types/node": "22.7.5",
    "@types/twilio": "3.19.2",
    "@types/uuid": "10.0.0",
    "@typescript-eslint/eslint-plugin": "8.56.0",
    "@typescript-eslint/parser": "8.56.0",
    "@typescript-eslint/typescript-estree": "^8.56.0",
    "@typescript-eslint/utils": "^8.56.0",
    "@vitest/coverage-v8": "4.0.16",
    "eslint": "8.57.1",
    "eslint-config-prettier": "10.1.8",
    "prettier": "3.8.1",
    "vitest": "4.0.16"
  }
}
