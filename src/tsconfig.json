{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "types": ["node"],
    "strict": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".."
  },
  "include": [
    "**/*"
  ],
  "exclude": [
    "../node_modules",
    "../dist",
    // Legacy Fastify entry point — references fastify (not installed) and many
    // route/middleware modules that no longer exist in this layer.
    "index.ts",
    // Legacy Fastify routes — reference fastify and dozens of missing services
    // (TaskService, UserService, DisputeService, etc.) that live in backend/src/
    "routes/**/*",
    // Legacy Fastify middleware — references fastify and missing idempotency/rateLimiter
    "middleware/**/*",
    // AI orchestrator — references intents.js, tools.js, prompts/* modules and
    // UserBrainService/ActionTrackerService that have not been ported to this layer
    "ai/orchestrator.ts",
    // Services with pre-existing type errors in database row mapping or
    // references to missing sibling services:
    // DisputeResolutionService: missing TaskService.js, UserService.js
    "services/DisputeResolutionService.ts",
    // TaskApplicationService: missing TaskService.js
    "services/TaskApplicationService.ts",
    // TaxReportingService: unknown row properties when mapping tax records
    "services/TaxReportingService.ts"
  ]
}
